# Devise Dashboard Backend — Environment Variables
# Copy this file to .env and fill in the values

# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.cxayrkozrivicvmbztqo.supabase.co:5432/postgres

# Supabase project URL
SUPABASE_URL=https://cxayrkozrivicvmbztqo.supabase.co

# Supabase service_role key (used by the desktop agent for ingest, bypasses RLS)
# Get this from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Supabase JWT secret (used to validate user auth tokens)
# Get this from: Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here
